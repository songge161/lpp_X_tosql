INSERT INTO entity (uuid, sid, name, data, type, privilege, del, del_people, input_people, update_date, input_date) VALUES ('hdy7e2m6wx', 'nadrebqvk1', '关于配合百诺医药出具股东穿透材料的用印申请', '{
    "id": 1932343605600202754,
    "fund_id": 2024092101000023,
    "fund_name": "济南三价融智知识产权股权投资合伙企业（有限合伙）",
    "is_use_sign": 1,
    "use_sign_type": "7,19",
    "approval_matter": "e山东百诺医药股份有限公司拟申请向不特定合格投资者公开发行股票并在北京证券交易所上市,根据中国证券监督管理委员会《证监会系统离职人员入股拟上市企业监管规定(试行)》等相关规定的要求，济南三价融智知识产权股权投资合伙企业(有限合伙)及其上层股东作为百诺医药的直接/间接股东，需要对三价融智合伙企业及其上层股东进行穿透核查，向上穿透股东涉及济南市股权投资母基金有限公司、济南财金投资管理有限公司，需配合出具材料如下：\n1. 财金管理公司营业执照、章程（复印件加盖公章，1式1份）；\n2. 母基金公司营业执照、章程（复印件加盖公章，1式1份）。",
    "advise": "建议配合企业出具股东穿透材料。",
    "initiat_dept": "",
